<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane fx:id="root" xmlns:fx="http://javafx.com/fxml"
            fx:controller="hexatorn.mysmaug.controller.MainController"
            stylesheets="@styles.css">
    <!-- Pasek tytułu (custom chrome, okno undecorated): tytuł z lewej, przyciski okna z prawej;
         przeciąganie po pasku przesuwa okno (onMousePressed/onMouseDragged). -->
    <top>
        <HBox styleClass="title-bar" onMousePressed="#onTitleBarPressed" onMouseDragged="#onTitleBarDragged">
            <Label text="MySmaug" styleClass="title-bar-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button styleClass="window-button" onAction="#onActionMinimalizuj">
                <graphic><FontIcon iconLiteral="mdi2w-window-minimize"/></graphic>
            </Button>
            <Button styleClass="window-button" onAction="#onActionMaksymalizuj">
                <graphic><FontIcon fx:id="btnMaksymalizuj" iconLiteral="mdi2w-window-maximize"/></graphic>
            </Button>
            <Button styleClass="window-button, window-button-close" onAction="#onActionZamknij">
                <graphic><FontIcon iconLiteral="mdi2c-close"/></graphic>
            </Button>
        </HBox>
    </top>
    <left>
        <VBox fx:id="sidebar" spacing="8.0">
            <Button fx:id="btnWprowadzanie" text="Wprowadzanie" maxWidth="Infinity"
                    styleClass="nav-button" onAction="#onActionWprowadzanie">
                <graphic><FontIcon iconLiteral="mdi2p-plus"/></graphic>
            </Button>
            <Button fx:id="btnPodsumowania" text="Podsumowania" maxWidth="Infinity"
                    styleClass="nav-button" onAction="#onActionPodsumowania">
                <graphic><FontIcon iconLiteral="mdi2c-chart-bar"/></graphic>
            </Button>
            <Button fx:id="btnUstawienia" text="Ustawienia" maxWidth="Infinity"
                    styleClass="nav-button" onAction="#onActionUstawienia">
                <graphic><FontIcon iconLiteral="mdi2c-cog"/></graphic>
            </Button>
            <Region VBox.vgrow="ALWAYS"/>
            <!-- Przełącznik motywu (Jasny / Ciemny / Fioletowy) — segmentowany pasek; zaznaczenie startowe ustawia kod wg OS. -->
            <HBox styleClass="theme-switch" spacing="0.0">
                <fx:define>
                    <ToggleGroup fx:id="grupaMotyw"/>
                </fx:define>
                <ToggleButton fx:id="tglMotywJasny" styleClass="theme-toggle" toggleGroup="$grupaMotyw"
                              onAction="#onActionMotywJasny">
                    <graphic><FontIcon iconLiteral="mdi2w-white-balance-sunny"/></graphic>
                    <tooltip><Tooltip text="Jasny"/></tooltip>
                </ToggleButton>
                <ToggleButton fx:id="tglMotywCiemny" styleClass="theme-toggle" toggleGroup="$grupaMotyw"
                              onAction="#onActionMotywCiemny">
                    <graphic><FontIcon iconLiteral="mdi2w-weather-night"/></graphic>
                    <tooltip><Tooltip text="Ciemny"/></tooltip>
                </ToggleButton>
                <ToggleButton fx:id="tglMotywFioletowy" styleClass="theme-toggle" toggleGroup="$grupaMotyw"
                              onAction="#onActionMotywFioletowy">
                    <graphic><FontIcon iconLiteral="mdi2p-palette"/></graphic>
                    <tooltip><Tooltip text="Fioletowy"/></tooltip>
                </ToggleButton>
            </HBox>
            <Button fx:id="btnZamknij" text="Zamknij" maxWidth="Infinity"
                    styleClass="close-button" onAction="#onActionZamknij">
                <graphic><FontIcon iconLiteral="mdi2c-close"/></graphic>
            </Button>
        </VBox>
    </left>
</BorderPane>
