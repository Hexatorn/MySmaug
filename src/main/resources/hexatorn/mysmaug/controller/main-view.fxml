<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="root" xmlns:fx="http://javafx.com/fxml"
            fx:controller="hexatorn.mysmaug.controller.MainController">
    <left>
        <VBox fx:id="sidebar" spacing="8.0">
            <Button fx:id="navWprowadzanie" text="Wprowadzanie" maxWidth="Infinity"
                    onAction="#onWprowadzanie"/>
            <Button fx:id="navPodsumowania" text="Podsumowania" maxWidth="Infinity"
                    onAction="#onPodsumowania"/>
            <Button fx:id="navUstawienia" text="Ustawienia" maxWidth="Infinity"
                    onAction="#onUstawienia"/>
        </VBox>
    </left>
</BorderPane>
